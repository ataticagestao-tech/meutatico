# ===== APP =====
APP_NAME=Tatica Gestap
DEBUG=true
API_PREFIX=/api/v1

# ===== DATABASE =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tatica_gestap
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===== REDIS =====
REDIS_URL=redis://redis:6379/0

# ===== JWT =====
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== SUPER ADMIN =====
SUPER_ADMIN_SECRET_KEY=dev-super-admin-secret-change-in-production!!

# ===== STORAGE =====
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./uploads

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@taticagestap.com.br
SMTP_FROM_NAME=Tatica Gestap

# ===== CORS =====
CORS_ORIGINS=["http://localhost:3000"]

# ===== FRONTEND =====
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Tatica Gestap

# ===== POSTGRES (Docker) =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tatica_gestap
